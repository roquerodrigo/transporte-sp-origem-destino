---
/**
 * The demand map: residences, workplaces (coloured by economic sector) and schools, each an
 * address-level point layer served from a single PMTiles file. At city zoom the points read
 * as a density cloud; zoom into a neighbourhood and they resolve to individual addresses.
 *
 * The basemap is CARTO raster (no API key), and both it and MapLibre's own chrome follow the
 * site theme.
 */
interface Props {
  altura?: string;
}
const { altura = "78vh" } = Astro.props;
const base = import.meta.env.BASE_URL;
const pmtiles = `${base}dados/demanda.pmtiles`;
---

<div class="mapa" data-pmtiles={pmtiles} style={`height: ${altura}`}></div>
<noscript><p>O mapa precisa de JavaScript. Os dados estão em <code>dados/demanda.pmtiles</code>.</p></noscript>

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";
  import { Protocol } from "pmtiles";

  const protocol = new Protocol();
  maplibregl.addProtocol("pmtiles", protocol.tile);

  // Grouped sector colours — the 14 survey sectors folded into the categories a reader tracks.
  const SETOR_COR: [number, string][] = [
    [4, "#e8590c"], // Comércio
    [3, "#9b1c31"], // Indústria
    [2, "#8d6e63"], // Construção
    [10, "#2e7d32"], // Saúde
    [11, "#00897b"], // Educação (serviço)
    [1, "#7cb342"], // Agropecuária
  ];
  const SERVICO_COR = "#1e6fd6"; // every other service sector

  const CAMADAS = {
    residencia: { rotulo: "Residências", cor: "#5b6bbf" },
    trabalho: { rotulo: "Trabalho", cor: SERVICO_COR },
    educacao: { rotulo: "Educação", cor: "#00897b" },
  } as const;

  const basemap = (dark: boolean) => {
    const variant = dark ? "dark_all" : "light_all";
    return {
      version: 8 as const,
      sources: {
        carto: {
          type: "raster" as const,
          tiles: ["a", "b"].map(
            (h) => `https://${h}.basemaps.cartocdn.com/${variant}/{z}/{x}/{y}@2x.png`,
          ),
          tileSize: 256,
          attribution:
            '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · ' +
            '© <a href="https://carto.com/attributions">CARTO</a> · Pesquisa OD 2023 Metrô-SP · IBGE',
        },
      },
      layers: [{ id: "carto", type: "raster" as const, source: "carto" }],
    };
  };
  const isDark = () =>
    (document.documentElement.dataset.theme ??
      (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")) === "dark";

  class Controle implements maplibregl.IControl {
    private readonly el = document.createElement("div");
    constructor(private readonly aoMudar: (camada: string) => void) {}
    onAdd(): HTMLElement {
      this.el.className = "maplibregl-ctrl maplibregl-ctrl-group painel";
      this.el.innerHTML = `<p class="painel-titulo">Camada</p>`;
      Object.entries(CAMADAS).forEach(([id, { rotulo, cor }], i) => {
        const label = document.createElement("label");
        const input = document.createElement("input");
        input.type = "radio";
        input.name = "camada";
        input.value = id;
        input.checked = i === 0;
        input.addEventListener("change", () => this.aoMudar(id));
        const swatch = `<span class="swatch" style="background:${cor}"></span>`;
        label.innerHTML = swatch;
        label.append(input, document.createTextNode(rotulo));
        this.el.append(label);
      });
      return this.el;
    }
    onRemove() {
      this.el.remove();
    }
  }

  function draw(container: HTMLElement) {
    const map = new maplibregl.Map({
      container,
      style: basemap(isDark()),
      center: [-46.63, -23.55],
      zoom: 9.4,
      attributionControl: { compact: true },
    });
    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");
    map.addControl(new maplibregl.FullscreenControl(), "top-right");

    let atual = "residencia";
    map.addControl(
      new Controle((camada) => {
        atual = camada;
        for (const id of Object.keys(CAMADAS)) {
          if (map.getLayer(id)) {
            map.setLayoutProperty(id, "visibility", camada === id ? "visible" : "none");
          }
        }
      }),
      "top-left",
    );

    new MutationObserver(() => {
      const wanted = basemap(isDark());
      if (JSON.stringify(map.getStyle().sources) !== JSON.stringify(wanted.sources)) {
        map.setStyle(wanted, { diff: false });
      }
    }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });

    let first = true;
    map.on("style.load", () => {
      map.addSource("demanda", { type: "vector", url: `pmtiles://${container.dataset.pmtiles}` });

      type Expr = maplibregl.DataDrivenPropertyValueSpecification<number>;
      const raio = ["interpolate", ["linear"], ["zoom"], 8, 1, 13, 2.6, 16, 5] as Expr;
      const opacidade = ["interpolate", ["linear"], ["zoom"], 8, 0.35, 14, 0.85] as Expr;

      map.addLayer({
        id: "residencia",
        type: "circle",
        source: "demanda",
        "source-layer": "residencia",
        paint: {
          "circle-radius": raio,
          "circle-color": CAMADAS.residencia.cor,
          "circle-opacity": opacidade,
        },
      });
      map.addLayer({
        id: "trabalho",
        type: "circle",
        source: "demanda",
        "source-layer": "trabalho",
        layout: { visibility: "none" },
        paint: {
          "circle-radius": raio,
          "circle-color": ["match", ["get", "sector"], ...SETOR_COR.flat(), SERVICO_COR] as
            unknown as maplibregl.DataDrivenPropertyValueSpecification<string>,
          "circle-opacity": opacidade,
        },
      });
      map.addLayer({
        id: "educacao",
        type: "circle",
        source: "demanda",
        "source-layer": "educacao",
        layout: { visibility: "none" },
        paint: {
          "circle-radius": raio,
          "circle-color": CAMADAS.educacao.cor,
          "circle-opacity": opacidade,
        },
      });

      for (const id of Object.keys(CAMADAS)) {
        map.setLayoutProperty(id, "visibility", atual === id ? "visible" : "none");
      }

      if (!first) return;
      first = false;

      const popup = new maplibregl.Popup({
        closeButton: false,
        offset: 10,
        className: "mapa-popup",
        focusAfterOpen: false,
      });
      map.on("mousemove", ["residencia", "trabalho", "educacao"], (event) => {
        const f = event.features?.[0];
        if (!f) return;
        map.getCanvas().style.cursor = "pointer";
        const texto = f.properties.sector_name
          ? `${f.properties.sector_name} · ~${f.properties.weight} empregos`
          : `~${f.properties.weight} pessoas`;
        popup.setLngLat(event.lngLat).setText(texto).addTo(map);
      });
      map.on("mouseleave", ["residencia", "trabalho", "educacao"], () => {
        map.getCanvas().style.cursor = "";
        popup.remove();
      });
    });
  }

  document.querySelectorAll<HTMLElement>(".mapa").forEach(draw);
</script>

<style>
  .mapa {
    width: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    margin-block: 1rem 1.5rem;
    border: 1px solid var(--sl-color-hairline);
  }
</style>

<style is:global>
  .painel {
    padding: 0.5rem 0.65rem;
    font-size: 0.8rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
  }
  .painel-titulo {
    margin: 0 0 0.3rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }
  .painel label {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    cursor: pointer;
    white-space: nowrap;
  }
  .painel .swatch {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    display: inline-block;
  }
  .mapa .maplibregl-ctrl-group,
  .mapa .maplibregl-popup-content,
  .mapa .maplibregl-ctrl-attrib.maplibregl-compact,
  .mapa .maplibregl-ctrl-attrib {
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
  }
  :root[data-theme="dark"] .mapa .maplibregl-ctrl-group button .maplibregl-ctrl-icon,
  :root[data-theme="dark"] .mapa .maplibregl-ctrl-attrib-button {
    filter: invert(1);
  }
</style>
