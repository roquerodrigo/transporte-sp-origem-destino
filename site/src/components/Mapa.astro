---
/**
 * The demand map: residents, workplaces and schools as weighted heatmaps, one layer each,
 * served from a single PMTiles file. Every point is a real surveyed location; its FE_PESS
 * expansion weight drives the heat, so a dwelling that stands for many people burns brighter.
 *
 * The basemap is CARTO raster (no API key), and both it and MapLibre's own chrome follow the
 * site theme.
 */
interface Props {
  altura?: string;
}
const { altura = "78vh" } = Astro.props;
const base = import.meta.env.BASE_URL;
const pmtiles = `${base}dados/demanda.pmtiles`;
---

<div class="mapa" data-pmtiles={pmtiles} style={`height: ${altura}`}></div>
<noscript><p>O mapa precisa de JavaScript. Os dados estão em <code>dados/demanda.pmtiles</code>.</p></noscript>

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";
  import { PMTiles, Protocol } from "pmtiles";

  const protocol = new Protocol();
  maplibregl.addProtocol("pmtiles", protocol.tile);

  /**
   * Read the archive from memory instead of over HTTP range requests.
   *
   * The site is fronted by Cloudflare, which strips `Accept-Ranges` and compresses
   * `application/octet-stream`, so the byte-range reads PMTiles normally uses come back
   * corrupt. Fetching the whole file once and serving its bytes from an ArrayBuffer sidesteps
   * that entirely — one plain GET, no ranges.
   */
  class BufferSource {
    constructor(
      private readonly buffer: ArrayBuffer,
      private readonly key: string,
    ) {}
    getKey() {
      return this.key;
    }
    async getBytes(offset: number, length: number) {
      return { data: this.buffer.slice(offset, offset + length) };
    }
  }

  // A per-layer heat ramp: transparent at no density, the layer's hue as it builds up.
  const rampa = (r: number, g: number, b: number, dr: number, dg: number, db: number) =>
    [
      "interpolate",
      ["linear"],
      ["heatmap-density"],
      0,
      `rgba(${r},${g},${b},0)`,
      0.3,
      `rgba(${r},${g},${b},0.4)`,
      0.6,
      `rgba(${r},${g},${b},0.7)`,
      1,
      `rgba(${dr},${dg},${db},0.9)`,
    ] as unknown as maplibregl.ExpressionSpecification;

  const CAMADAS = {
    residencia: { rotulo: "Residências", cor: "#5b6bbf", rampa: rampa(91, 107, 191, 58, 73, 160) },
    trabalho: { rotulo: "Trabalho", cor: "#1e6fd6", rampa: rampa(30, 111, 214, 20, 80, 156) },
    educacao: { rotulo: "Educação", cor: "#00897b", rampa: rampa(0, 137, 123, 0, 95, 85) },
  } as const;
  const IDS = Object.keys(CAMADAS);

  const basemap = (dark: boolean) => {
    const variant = dark ? "dark_all" : "light_all";
    return {
      version: 8 as const,
      sources: {
        carto: {
          type: "raster" as const,
          tiles: ["a", "b"].map(
            (h) => `https://${h}.basemaps.cartocdn.com/${variant}/{z}/{x}/{y}@2x.png`,
          ),
          tileSize: 256,
          attribution:
            '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · ' +
            '© <a href="https://carto.com/attributions">CARTO</a> · Pesquisa OD 2023 Metrô-SP',
        },
      },
      layers: [{ id: "carto", type: "raster" as const, source: "carto" }],
    };
  };
  const isDark = () =>
    (document.documentElement.dataset.theme ??
      (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")) === "dark";

  class Controle implements maplibregl.IControl {
    private readonly el = document.createElement("div");
    constructor(private readonly aoMudar: (camada: string) => void) {}
    onAdd(): HTMLElement {
      this.el.className = "maplibregl-ctrl maplibregl-ctrl-group painel";
      this.el.innerHTML = `<p class="painel-titulo">Camada</p>`;
      Object.entries(CAMADAS).forEach(([id, { rotulo, cor }], i) => {
        const label = document.createElement("label");
        const input = document.createElement("input");
        input.type = "radio";
        input.name = "camada";
        input.value = id;
        input.checked = i === 0;
        input.addEventListener("change", () => this.aoMudar(id));
        const swatch = `<span class="swatch" style="background:${cor}"></span>`;
        label.innerHTML = swatch;
        label.append(input, document.createTextNode(rotulo));
        this.el.append(label);
      });
      return this.el;
    }
    onRemove() {
      this.el.remove();
    }
  }

  async function draw(container: HTMLElement) {
    const url = container.dataset.pmtiles!;
    const buffer = await fetch(url).then((r) => r.arrayBuffer());
    protocol.add(new PMTiles(new BufferSource(buffer, url) as any));

    const map = new maplibregl.Map({
      container,
      style: basemap(isDark()),
      center: [-46.63, -23.55],
      zoom: 9.4,
      attributionControl: { compact: true },
    });
    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");
    map.addControl(new maplibregl.FullscreenControl(), "top-right");

    let atual = "residencia";
    map.addControl(
      new Controle((camada) => {
        atual = camada;
        for (const id of IDS) {
          if (map.getLayer(id)) {
            map.setLayoutProperty(id, "visibility", camada === id ? "visible" : "none");
          }
        }
      }),
      "top-left",
    );

    new MutationObserver(() => {
      const wanted = basemap(isDark());
      if (JSON.stringify(map.getStyle().sources) !== JSON.stringify(wanted.sources)) {
        map.setStyle(wanted, { diff: false });
      }
    }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });

    map.on("style.load", () => {
      map.addSource("demanda", { type: "vector", url: `pmtiles://${url}` });

      type Expr = maplibregl.ExpressionSpecification;
      // FE_PESS ranges into the low thousands; cap its pull so a few huge weights don't wash out.
      const peso = ["interpolate", ["linear"], ["get", "weight"], 0, 0, 1500, 1] as unknown as Expr;
      const intensidade = ["interpolate", ["linear"], ["zoom"], 5, 1, 11, 1.6, 15, 3] as unknown as Expr;
      const raio = ["interpolate", ["linear"], ["zoom"], 5, 2, 9, 9, 13, 20, 15, 28] as unknown as Expr;

      for (const [id, { rampa: cores }] of Object.entries(CAMADAS)) {
        map.addLayer({
          id,
          type: "heatmap",
          source: "demanda",
          "source-layer": id,
          layout: { visibility: atual === id ? "visible" : "none" },
          paint: {
            "heatmap-weight": peso,
            "heatmap-intensity": intensidade,
            "heatmap-radius": raio,
            "heatmap-color": cores,
            "heatmap-opacity": 0.85,
          },
        });
      }
    });
  }

  document.querySelectorAll<HTMLElement>(".mapa").forEach(draw);
</script>

<style>
  .mapa {
    width: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    margin-block: 1rem 1.5rem;
  }
</style>
