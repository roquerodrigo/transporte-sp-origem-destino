---
const base = import.meta.env.BASE_URL;
const arquivos = [
  {
    nome: "fluxos.parquet",
    formato: "Parquet",
    tamanho: "1,9 MB",
    descricao: "Colunar comprimido, tipado. Para análise (pandas, DuckDB, Polars).",
  },
  {
    nome: "fluxos.csv",
    formato: "CSV",
    tamanho: "7,6 MB",
    descricao: "Texto separado por vírgula, com cabeçalho. Abre em qualquer planilha.",
  },
];
---

<div class="downloads">
  {
    arquivos.map((arquivo) => (
      <a class="download" href={`${base}dados/${arquivo.nome}`} download>
        <span class="formato">{arquivo.formato}</span>
        <span class="corpo">
          <span class="nome">{arquivo.nome}</span>
          <span class="descricao">{arquivo.descricao}</span>
        </span>
        <span class="tamanho">{arquivo.tamanho}</span>
      </a>
    ))
  }
</div>

<style>
  .downloads {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.5rem 0;
  }
  .download {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background-color 0.15s;
  }
  .download:hover {
    border-color: var(--sl-color-accent);
    background-color: var(--sl-color-gray-6);
  }
  .formato {
    flex-shrink: 0;
    min-width: 4.5rem;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.35rem 0.6rem;
    border-radius: 0.35rem;
    background-color: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
  }
  .corpo {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex-grow: 1;
  }
  .nome {
    font-weight: 600;
    font-family: var(--sl-font-mono, monospace);
  }
  .descricao {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }
  .tamanho {
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-gray-3);
  }
</style>
