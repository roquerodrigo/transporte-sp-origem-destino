---
const base = import.meta.env.BASE_URL;
const grupos = [
  {
    titulo: "Importação — ~100 mil feixes",
    nota: "Orçamento fixo de feixes, tamanho enxuto. É o que o mapa usa.",
    arquivos: [
      {
        nome: "fluxos.parquet",
        formato: "Parquet",
        tamanho: "1,9 MB",
        descricao: "Colunar comprimido, tipado. Para análise (pandas, DuckDB, Polars).",
      },
      {
        nome: "fluxos.csv",
        formato: "CSV",
        tamanho: "6,9 MB",
        descricao: "Texto separado por vírgula, com cabeçalho. Abre em qualquer planilha.",
      },
    ],
  },
  {
    titulo: "Base completa — ~713 mil feixes (comprimida)",
    nota: "A resolução máxima: um feixe por ~50 viagens. Mesmas colunas.",
    arquivos: [
      {
        nome: "fluxos_completo.parquet",
        formato: "Parquet",
        tamanho: "7,4 MB",
        descricao: "Já comprimido internamente (zstd). Abre direto, sem descompactar.",
      },
      {
        nome: "fluxos_completo.csv.gz",
        formato: "CSV.gz",
        tamanho: "8,2 MB",
        descricao: "CSV gzipado (~48 MB descompactado). Use gunzip / descompactador.",
      },
    ],
  },
];
---

<div class="grupos">
  {
    grupos.map((grupo) => (
      <section class="grupo">
        <h3 class="grupo-titulo">{grupo.titulo}</h3>
        <p class="grupo-nota">{grupo.nota}</p>
        <div class="downloads">
          {grupo.arquivos.map((arquivo) => (
            <a class="download" href={`${base}dados/${arquivo.nome}`} download>
              <span class="formato">{arquivo.formato}</span>
              <span class="corpo">
                <span class="nome">{arquivo.nome}</span>
                <span class="descricao">{arquivo.descricao}</span>
              </span>
              <span class="tamanho">{arquivo.tamanho}</span>
            </a>
          ))}
        </div>
      </section>
    ))
  }
</div>

<style>
  .grupos {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin: 1.5rem 0;
  }
  .grupo-titulo {
    margin: 0;
    font-size: 1rem;
  }
  .grupo-nota {
    margin: 0.2rem 0 0.75rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }
  .downloads {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .download {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background-color 0.15s;
  }
  .download:hover {
    border-color: var(--sl-color-accent);
    background-color: var(--sl-color-gray-6);
  }
  .formato {
    flex-shrink: 0;
    min-width: 4.5rem;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.35rem 0.6rem;
    border-radius: 0.35rem;
    background-color: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
  }
  .corpo {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex-grow: 1;
  }
  .nome {
    font-weight: 600;
    font-family: var(--sl-font-mono, monospace);
  }
  .descricao {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }
  .tamanho {
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-gray-3);
  }
</style>
