---
const base = import.meta.env.BASE_URL;
const grupos = [
  {
    titulo: "Completo — ~113 mil viagens",
    nota: "Todas as viagens geolocalizadas da pesquisa.",
    arquivos: [
      { nome: "fluxos.parquet", formato: "Parquet", tamanho: "1,9 MB" },
      { nome: "fluxos.csv", formato: "CSV", tamanho: "7,6 MB" },
    ],
  },
  {
    titulo: "Leve — ~50 mil viagens",
    nota: "Amostra ponderada; soma as mesmas ~35,7 M viagens/dia.",
    arquivos: [
      { nome: "fluxos_50k.parquet", formato: "Parquet", tamanho: "0,95 MB" },
      { nome: "fluxos_50k.csv", formato: "CSV", tamanho: "3,4 MB" },
    ],
  },
  {
    titulo: "Mínimo — ~20 mil viagens",
    nota: "Amostra ponderada; soma as mesmas ~35,7 M viagens/dia.",
    arquivos: [
      { nome: "fluxos_20k.parquet", formato: "Parquet", tamanho: "0,50 MB" },
      { nome: "fluxos_20k.csv", formato: "CSV", tamanho: "1,4 MB" },
    ],
  },
];
---

<div class="grupos">
  {
    grupos.map((grupo) => (
      <section class="grupo">
        <h3 class="grupo-titulo">{grupo.titulo}</h3>
        <p class="grupo-nota">{grupo.nota}</p>
        <div class="downloads">
          {grupo.arquivos.map((arquivo) => (
            <a class="download" href={`${base}dados/${arquivo.nome}`} download>
              <span class="formato">{arquivo.formato}</span>
              <span class="nome">{arquivo.nome}</span>
              <span class="tamanho">{arquivo.tamanho}</span>
            </a>
          ))}
        </div>
      </section>
    ))
  }
</div>

<style>
  .grupos {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    margin: 1.5rem 0;
  }
  .grupo-titulo {
    margin: 0;
    font-size: 1rem;
  }
  .grupo-nota {
    margin: 0.2rem 0 0.6rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }
  .downloads {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .download {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.7rem 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background-color 0.15s;
  }
  .download:hover {
    border-color: var(--sl-color-accent);
    background-color: var(--sl-color-gray-6);
  }
  .formato {
    flex-shrink: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.5rem;
    border-radius: 0.35rem;
    background-color: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
  }
  .nome {
    font-weight: 600;
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.9rem;
  }
  .tamanho {
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
  }
</style>
